# 데이터 출처 선택: csv | supabase  (미설정 시 csv)
PRODUCT_DATA_SOURCE=csv

# --- Supabase (PRODUCT_DATA_SOURCE=supabase 일 때 필요) ---
# 공개 키 (브라우저 노출 가능)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
# 구형 프로젝트는 위 대신 아래 키명을 사용해도 자동 인식됩니다.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 서버 전용 secret 키 — 절대 NEXT_PUBLIC_ 접두사로 노출 금지, 브라우저로 전달 금지
SUPABASE_SECRET_KEY=YOUR_SECRET_KEY
# 구형 프로젝트는 위 대신 아래 키명을 사용해도 자동 인식됩니다.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 관리자 허용 이메일 (쉼표로 여러 개) — 관리자 콘솔/업로드 API 접근 제어
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# 실제 키가 담긴 .env.local / .env 는 커밋하지 마세요 (.gitignore 에 의해 무시됨).
